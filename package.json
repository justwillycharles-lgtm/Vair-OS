{
  "name": "vairos",
  "version": "0.1.0",
  "private": true,
  "description": "Vair OS - Think Less. Do More.",
  "author": "Vair Team",
  "license": "MIT",

  "packageManager": "npm@10",

  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],

  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write ."
  },

  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.4",
    "prettier": "^3.3.3"
  },

  "engines": {
    "node": ">=20"
  }
}
