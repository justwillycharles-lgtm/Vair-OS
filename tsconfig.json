{
  "$schema": "https://json.schemastore.org/tsconfig",

  "compilerOptions": {
    "target": "ES2022",

    "module": "ESNext",

    "moduleResolution": "Bundler",

    "lib": [
      "ES2022",
      "DOM"
    ],

    "jsx": "react-jsx",

    "strict": true,

    "allowJs": false,

    "resolveJsonModule": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "isolatedModules": true,

    "skipLibCheck": true,

    "noEmit": true,

    "baseUrl": ".",

    "paths": {
      "@/*": [
        "./*"
      ],
      "@ui/*": [
        "packages/ui/*"
      ],
      "@theme/*": [
        "packages/theme/*"
      ],
      "@utils/*": [
        "packages/utils/*"
      ],
      "@types/*": [
        "packages/types/*"
      ]
    }
  },

  "exclude": [
    "node_modules",
    "dist"
  ]
}
